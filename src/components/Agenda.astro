---
import agendaData from '../data/agenda.json';
import { t, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? 'pl') as Lang;
const agendaLocale = t(lang, 'agenda.locale');
const dayLabel = t(lang, 'agenda.day');

const typeStyles: Record<string, string> = {
  keynote:  'bg-accent/10 text-accent border-accent/30',
  talk:     'bg-surface/40 text-gray-300 border-surface',
  workshop: 'bg-neon-purple/10 text-neon-purple border-neon-purple/30',
  panel:    'bg-neon-yellow/10 text-neon-yellow border-neon-yellow/30',
  logistics:'bg-transparent text-gray-600 border-transparent',
};
---

<section id="agenda" class="max-w-7xl mx-auto px-6 py-24 scroll-mt-36">
  <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-14">
    <div>
      <p class="font-mono text-xs tracking-widest text-accent mb-2 uppercase">{t(lang, 'agenda.eyebrow')}</p>
      <h2 class="font-display font-bold text-4xl text-white leading-tight" style="text-shadow: 0 0 20px rgba(0,245,255,0.3);">{t(lang, 'agenda.title')}</h2>
    </div>
    <p class="font-mono text-sm text-gray-500">
      {agendaData.dates} &nbsp;·&nbsp; {agendaData.venue}
    </p>
  </div>

  <div class="flex gap-2 mb-10 flex-wrap" role="tablist" aria-label="Conference days">
    {agendaData.days.map((day, i) => (
      <button
        role="tab"
        data-tab={`day-${i}`}
        aria-selected={i === 0 ? 'true' : 'false'}
        aria-controls={`panel-day-${i}`}
        class:list={[
          'agenda-tab px-5 py-2.5 font-mono text-sm transition-all duration-200 border',
          i === 0
            ? 'bg-accent text-void border-accent font-bold shadow-[0_0_20px_rgba(0,245,255,0.4)]'
            : 'bg-transparent text-gray-400 border-accent/20 [@media(hover:hover)]:hover:border-accent/50 [@media(hover:hover)]:hover:text-accent',
        ]}
        style="clip-path: polygon(6px 0%, 100% 0%, calc(100% - 6px) 100%, 0% 100%);"
      >
        {`${dayLabel} ${i + 1}`}
        <span class="ml-2 opacity-60 text-xs hidden sm:inline">
          {new Date(day.date).toLocaleDateString(agendaLocale, { day: 'numeric', month: 'short' })}
        </span>
      </button>
    ))}
  </div>

  {agendaData.days.map((day, i) => (
    <div
      id={`panel-day-${i}`}
      role="tabpanel"
      class:list={['agenda-panel space-y-3', i !== 0 && 'hidden']}
    >
      <p class="font-mono text-xs text-gray-600 mb-6 tracking-widest uppercase">{day.label}</p>

      {day.tracks.map((session) => (
        <div class:list={[
          'grid grid-cols-[72px_1fr] gap-4 p-4 border transition-all duration-200',
          session.type === 'logistics'
            ? 'opacity-30'
            : 'bg-surface/20 border-accent/10 hover:border-accent/30 hover:shadow-[0_0_20px_rgba(0,245,255,0.05)] hover:bg-surface/30',
        ]}
          style={session.type !== 'logistics' ? 'clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px));' : ''}
        >
          <div class="font-mono text-sm text-gray-500 pt-0.5">{session.time}</div>
          <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-3">
            <div class="flex-1">
              <div class="flex flex-wrap items-center gap-2 mb-1">
                {session.type !== 'logistics' && (
                  <span class:list={[
                    'inline-block px-2 py-0.5 rounded border text-[10px] font-mono uppercase tracking-wider',
                    typeStyles[session.type] ?? typeStyles.talk,
                  ]}>
                    {session.type}
                  </span>
                )}
                {session.tags?.map(tag => (
                  <span class="font-mono text-[10px] text-gray-600">#{tag}</span>
                ))}
              </div>
              <p class:list={[
                'font-sans font-medium leading-snug',
                session.type === 'keynote' ? 'text-white text-base' : 'text-gray-300 text-sm',
              ]}>
                {session.title}
              </p>
            </div>
            {session.speaker && (
              <p class="font-mono text-xs text-gray-500 sm:text-right shrink-0 max-w-[200px]">{session.speaker}</p>
            )}
          </div>
        </div>
      ))}
    </div>
  ))}
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('.agenda-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab!;
      document.querySelectorAll('.agenda-tab').forEach(t => {
        const active = t === tab;
        t.setAttribute('aria-selected', String(active));
        t.classList.toggle('bg-accent',       active);
        t.classList.toggle('bg-transparent',  !active);
        t.classList.toggle('text-void',       active);
        t.classList.toggle('border-accent',   active);
        t.classList.toggle('font-bold',       active);
        t.classList.toggle('shadow-[0_0_20px_rgba(0,245,255,0.4)]', active);
        t.classList.toggle('text-gray-400',   !active);
        t.classList.toggle('border-accent/20', !active);
      });
      document.querySelectorAll('.agenda-panel').forEach(panel => {
        panel.classList.toggle('hidden', panel.id !== `panel-${target}`);
      });
    });
  });
</script>
