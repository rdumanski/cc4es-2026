---
import Countdown from './Countdown.tsx';
import HeroAnimations from './HeroAnimations.tsx';
import { t, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? 'pl') as Lang;
---

<section
  id="hero"
  class="relative min-h-screen flex items-center px-6 pt-36 pb-16 overflow-hidden"
  aria-label="CC4ES 2026 hero"
>
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/2 left-1/4 -translate-x-1/2 -translate-y-1/2
                w-[700px] h-[700px] rounded-full
                bg-[radial-gradient(ellipse_at_center,rgba(0,245,255,0.10)_0%,transparent_65%)]" />
    <div class="absolute top-1/3 right-1/4 translate-x-1/2 -translate-y-1/2
                w-[500px] h-[500px] rounded-full
                bg-[radial-gradient(ellipse_at_center,rgba(191,0,255,0.08)_0%,transparent_65%)]" />
  </div>

  <div class="relative z-10 max-w-5xl mx-auto w-full flex flex-col items-center gap-8">
    <HeroAnimations
      client:load
      badge={t(lang, 'hero.badge')}
      subtitle={t(lang, 'hero.subtitle')}
      date={t(lang, 'hero.date')}
      location={t(lang, 'hero.location')}
      learnMore={t(lang, 'hero.learnMore')}
      contact={t(lang, 'hero.contact')}
      lang={lang}
    />

    <div class="flex flex-col items-center gap-2">
      <p class="font-mono text-[10px] tracking-widest text-gray-600 uppercase">
        &#9632; {t(lang, 'hero.countdown')}
      </p>
      <Countdown
        client:load
        labels={[t(lang, 'time.days'), t(lang, 'time.hrs'), t(lang, 'time.min'), t(lang, 'time.sec')]}
      />
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 opacity-30" aria-hidden="true">
    <span class="font-mono text-[10px] tracking-widest text-gray-500">SCROLL</span>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-500 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>
