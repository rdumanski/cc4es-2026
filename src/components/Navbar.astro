---
import { t, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? 'pl') as Lang;
const otherLang = lang === 'pl' ? 'en' : 'pl';

// Build the alternate-language path by swapping the lang segment
const currentPath = Astro.url.pathname;
const otherPath = currentPath.replace(`/${lang}/`, `/${otherLang}/`).replace(`/${lang}`, `/${otherLang}`);

const navLinks = [
  { label: t(lang, 'nav.about'),  href: `/${lang}/#about`    },
  { label: t(lang, 'nav.tracks'), href: `/${lang}/#workshops` },
  { label: t(lang, 'nav.agenda'), href: `/${lang}/#agenda`    },
  { label: t(lang, 'nav.cfp'),    href: `/${lang}/cfp`        },
];
---

<header
  class="fixed top-[64px] inset-x-0 z-40 border-b border-accent/20 backdrop-blur-md bg-void/90"
  style="box-shadow: 0 1px 30px rgba(0,245,255,0.06);"
>
  <nav
    class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between"
    aria-label="Main navigation"
  >
    <!-- Brand -->
    <a href={`/${lang}/`} class="flex items-center gap-3 group" aria-label="CC4ES 2026 home">
      <span class="font-mono font-bold text-sm text-accent tracking-widest" style="text-shadow: 0 0 10px rgba(0,245,255,0.5);">CC4ES 2026</span>
      <span class="relative flex h-2 w-2" aria-hidden="true">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8" role="list">
      {navLinks.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class="font-mono text-sm text-gray-400 hover:text-accent transition-colors duration-200 relative
                   after:absolute after:-bottom-1 after:left-0 after:h-px after:w-0 after:bg-accent
                   after:transition-all after:duration-300 hover:after:w-full"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Language switcher -->
    <a
      href={otherPath}
      class="hidden md:inline-flex items-center gap-1.5 px-3 py-1.5
             border border-accent/30 text-accent font-mono text-xs tracking-widest uppercase
             hover:bg-accent hover:text-void transition-all duration-200
             hover:shadow-[0_0_15px_rgba(0,245,255,0.3)]"
      style="clip-path: polygon(4px 0%, 100% 0%, calc(100% - 4px) 100%, 0% 100%);"
      aria-label={`Switch to ${otherLang === 'en' ? 'English' : 'Polish'}`}
    >
      {otherLang.toUpperCase()}
    </a>

    <!-- Mobile hamburger -->
    <label class="md:hidden cursor-pointer p-2 -mr-2 text-gray-400 hover:text-accent transition-colors" aria-label="Toggle menu">
      <input type="checkbox" id="mobile-menu-toggle" class="peer sr-only" />
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 peer-checked:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden peer-checked:block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </label>
  </nav>

  <!-- Mobile dropdown -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-accent/20 bg-void/95 backdrop-blur-md px-6 py-4"
  >
    <ul class="flex flex-col gap-4" role="list">
      {navLinks.map(({ label, href }) => (
        <li>
          <a href={href} class="font-mono text-sm text-gray-300 hover:text-accent transition-colors">
            &gt; {label}
          </a>
        </li>
      ))}
      <li class="pt-3 border-t border-accent/20">
        <a
          href={otherPath}
          class="inline-flex items-center gap-2 font-mono text-sm text-accent hover:text-white transition-colors"
        >
          &gt; {otherLang.toUpperCase()} — {otherLang === 'en' ? 'English' : 'Polski'}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle') as HTMLInputElement;
  const menu   = document.getElementById('mobile-menu') as HTMLDivElement;

  toggle?.addEventListener('change', () => {
    menu.classList.toggle('hidden', !toggle.checked);
  });

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      toggle.checked = false;
      menu.classList.add('hidden');
    });
  });
</script>
