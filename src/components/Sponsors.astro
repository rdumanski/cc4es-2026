---
import sponsorsData from '../data/sponsors.json';
import { t, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? 'pl') as Lang;
---

<section id="sponsors" class="max-w-7xl mx-auto px-6 py-24 scroll-mt-36">
  <div class="mb-14">
    <p class="font-mono text-xs tracking-widest text-accent mb-2 uppercase">{t(lang, 'sponsors.eyebrow')}</p>
    <h2 class="font-display font-bold text-4xl text-white leading-tight" style="text-shadow: 0 0 20px rgba(0,245,255,0.3);">{t(lang, 'sponsors.title')}</h2>
  </div>

  <div class="space-y-12">
    {sponsorsData.tiers.map(tier => (
      <div>
        <div class="flex items-center gap-4 mb-6">
          <span class="font-mono text-xs tracking-widest text-gray-600 uppercase">{tier.name}</span>
          <div class="flex-1 h-px bg-gradient-to-r from-accent/20 to-transparent" />
        </div>
        <div class:list={['flex flex-wrap gap-4', tier.name === 'Strategic Partner' ? 'items-center' : '']}>
          {tier.sponsors.map(sponsor => (
            <a
              href={sponsor.url}
              target={sponsor.url !== '#' ? '_blank' : undefined}
              rel="noopener noreferrer"
              class:list={[
                'group flex items-center justify-center border border-accent/15 bg-surface/30',
                'hover:border-accent/40 transition-all duration-200 hover:shadow-[0_0_15px_rgba(0,245,255,0.1)]',
                'font-mono text-sm text-gray-500 hover:text-accent',
                tier.name === 'Strategic Partner' ? 'px-10 py-6 text-base font-semibold text-gray-300 min-w-[200px]'
                : tier.name === 'Platinum'        ? 'px-8 py-5 min-w-[160px]'
                :                                   'px-6 py-4 min-w-[130px]',
              ]}
            >
              {sponsor.name}
            </a>
          ))}
          <a
            href="mailto:sponsorship@cc4es.pl"
            class:list={[
              'flex items-center justify-center border border-dashed border-accent/15',
              'hover:border-accent/40 transition-all duration-200',
              'font-mono text-xs text-gray-700 hover:text-accent hover:shadow-[0_0_10px_rgba(0,245,255,0.1)]',
              tier.name === 'Strategic Partner' ? 'px-10 py-6 min-w-[200px]'
              : tier.name === 'Platinum'        ? 'px-8 py-5 min-w-[160px]'
              :                                   'px-6 py-4 min-w-[130px]',
            ]}
          >
            {t(lang, 'sponsors.yourBrand')}
          </a>
        </div>
      </div>
    ))}
  </div>
</section>
