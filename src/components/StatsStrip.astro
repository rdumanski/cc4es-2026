---
const stats = [
  { value: '3',      label: 'Conference Days'   },
  { value: '300+',   label: 'Expert Attendees'  },
  { value: '20+',    label: 'Sessions & Talks'  },
  { value: '10+',    label: 'Countries'         },
  { value: 'EU',     label: 'Hosted in Poland'  },
];
---

<div class="border-y border-accent/15 bg-surface/10" style="box-shadow: 0 0 40px rgba(0,245,255,0.04) inset;">
  <div class="max-w-7xl mx-auto px-6 py-6">
    <dl class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-6 lg:gap-0 lg:divide-x lg:divide-accent/10">
      {stats.map(({ value, label }) => (
        <div class="flex flex-col items-center lg:items-start lg:px-8 first:lg:pl-0 last:lg:pr-0">
          <dt class="font-display font-bold text-3xl text-accent" style="text-shadow: 0 0 10px rgba(0,245,255,0.6);">{value}</dt>
          <dd class="font-mono text-[11px] text-accent/40 tracking-widest uppercase mt-1">{label}</dd>
        </div>
      ))}
    </dl>
  </div>
</div>
