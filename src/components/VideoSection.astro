---
import { t, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? 'pl') as Lang;
const VIDEO_ID = 'lMCY0jg30uI';
---

<section id="video" class="max-w-7xl mx-auto px-6 py-24 scroll-mt-36">
  <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-10">
    <div>
      <p class="font-mono text-xs tracking-widest text-accent mb-2 uppercase">{t(lang, 'video.eyebrow')}</p>
      <h2 class="font-display font-bold text-4xl text-white leading-tight" style="text-shadow: 0 0 20px rgba(0,245,255,0.3);">{t(lang, 'video.title')}</h2>
    </div>
    <p class="font-mono text-sm text-gray-500 max-w-xs">{t(lang, 'video.subtitle')}</p>
  </div>

  <div class="relative w-full overflow-hidden border border-accent/20 aspect-video bg-surface/30 shadow-[0_0_60px_rgba(0,245,255,0.15)]"
       style="clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 20px 100%, 0 calc(100% - 20px));">
    <span class="absolute top-3 left-3 w-4 h-4 border-t-2 border-l-2 border-accent/40 z-10 pointer-events-none" aria-hidden="true" />
    <span class="absolute top-3 right-3 w-4 h-4 border-t-2 border-r-2 border-accent/40 z-10 pointer-events-none" aria-hidden="true" />
    <span class="absolute bottom-3 left-3 w-4 h-4 border-b-2 border-l-2 border-accent/40 z-10 pointer-events-none" aria-hidden="true" />
    <span class="absolute bottom-3 right-3 w-4 h-4 border-b-2 border-r-2 border-accent/40 z-10 pointer-events-none" aria-hidden="true" />
    <iframe
      src={`https://www.youtube-nocookie.com/embed/${VIDEO_ID}?rel=0&modestbranding=1&color=white`}
      title="CC4ES Conference recap video"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
      loading="lazy"
      class="absolute inset-0 w-full h-full"
    ></iframe>
  </div>
</section>
