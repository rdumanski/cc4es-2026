---
import Navbar from '../components/Navbar.astro';
import { t, type Lang } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
}

const lang = (Astro.currentLocale ?? 'pl') as Lang;

const {
  title = 'CC4ES 2026 — Cybersecurity Conference for Energy Sector',
  description = 'Cybersecurity Conference for Energy Sector (CC4ES) 2026. Organized by CERT PSE, in partnership with SANS Institute. Józefów, September 21–23, 2026.',
} = Astro.props;
---

<!doctype html>
<html lang={lang} class="dark scroll-smooth overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="X-Frame-Options" content="DENY" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=JetBrains+Mono:wght@400;600;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>

  <body class="bg-void text-gray-100 font-sans antialiased min-h-screen">
    <div class="fixed inset-0 bg-grid-pattern bg-grid-40 pointer-events-none z-0" aria-hidden="true"></div>

    <div class="fixed inset-0 pointer-events-none z-[60] overflow-hidden" aria-hidden="true">
      <div class="absolute inset-x-0 h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent animate-scanline opacity-40"></div>
    </div>

    <!-- Top banner – PSE + CERT PSE logos -->
    <div class="relative z-50 bg-white border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-6 py-2 flex items-center justify-between gap-6">
        <a href="https://www.pse.pl" target="_blank" rel="noopener noreferrer" aria-label="PSE website">
          <img src="/logo_pse.png" alt="PSE — Polskie Sieci Elektroenergetyczne" class="h-10 w-auto opacity-90 hover:opacity-100 transition-opacity" height="40" />
        </a>
        <a href="https://cert.pse.pl" target="_blank" rel="noopener noreferrer" aria-label="CERT PSE website">
          <img src="/logo_cert.png" alt="CERT PSE" class="h-10 w-auto opacity-90 hover:opacity-100 transition-opacity" height="40" />
        </a>
      </div>
    </div>

    <Navbar />

    <main class="relative z-10">
      <slot />
    </main>

    <footer class="relative z-10 border-t border-accent/20 mt-24 py-8 px-6 text-center text-xs text-gray-500 font-mono" style="box-shadow: 0 -1px 20px rgba(0,245,255,0.08);">
      <p>
        CC4ES 2026 &mdash; {t(lang, 'footer.org')}
        <span class="text-accent">CERT PSE</span>
        &middot; {t(lang, 'footer.partner')}:
        <span class="text-accent">SANS Institute</span>
        &middot; Holiday Inn Józefów
      </p>
      <p class="mt-1 opacity-50">
        &copy; {new Date().getFullYear()} CERT PSE. {t(lang, 'footer.rights')}
      </p>
    </footer>
  </body>
</html>
