---
// Redirect to preferred language based on browser, default to Polish
---
<html>
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content="0; url=/pl/" />
    <script>
      const lang = navigator.language?.startsWith('pl') ? 'pl' : 'en';
      window.location.replace(`/${lang}/`);
    </script>
  </head>
  <body></body>
</html>
